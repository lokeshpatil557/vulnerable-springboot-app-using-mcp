# security-mcp-server configuration
# Copy to .env and adjust as needed. Values shown are the documented defaults.

# Where the server should treat as the repo root. Walked up to nearest .git
# if unset.
# REPO_ROOT=C:/Users/You/Code/your-repo

LOG_LEVEL=info
AUDIT_LOG_PATH=.security-mcp/audit.jsonl
SCAN_TIMEOUT_MS=300000
MAX_CONCURRENT_SCANNERS=2

# Override scanner binary locations if they aren't on PATH.
# SEMGREP_PATH=
# GITLEAKS_PATH=
# TRIVY_PATH=
