{
  "name": "security-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for security scanning, tech-stack detection, and verified remediation",
  "type": "module",
  "license": "MIT",
  "bin": {
    "security-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "diff": "^5.2.0",
    "execa": "^8.0.1",
    "fast-glob": "^3.3.3",
    "p-limit": "^3.1.0",
    "pino": "^9.4.0",
    "uuid": "^14.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/diff": "^5.2.2",
    "@types/node": "^20.19.43",
    "esbuild": "^0.24.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
