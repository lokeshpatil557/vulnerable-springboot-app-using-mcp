{
  "mcpServers": {
    "security-mcp-server": {
      "type": "stdio",
      "command": "node",
      "args": ["../security-mcp-server/dist/index.js"],
      "env": {
        "LOG_LEVEL": "info",
        "ALLOW_APPLY_REMEDIATION": "1",
        "BLOCKED_ANCESTORS": "",
        "SECURITY_MCP_ALLOWED_ROOT": "${CLAUDE_PROJECT_DIR:-.}"
      }
    }
  }
}
